// HR System — Prisma schema
// MVP scope: auth, employee, attendance, leave, payroll basics, workflows, audit.
// SQLite for dev. Switch to PostgreSQL for prod by changing `provider`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Required for Neon / pgbouncer-pooled hosts: `prisma migrate` needs a
  // direct (unpooled) connection because pooled connections can't run
  // session-scoped commands. Falls back to the pooled url for local dev.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ────────────────────────────────────────────────────────────────────
// AUTH & RBAC
// ────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  hashedPassword String
  mfaEnabled     Boolean   @default(false)
  mfaSecret      String?
  status         String    @default("active") // active | suspended | invited
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  employee  Employee?
  userRoles UserRole[]
  approvals Approval[]    @relation("ApproverUser")
  audits    AuditLog[]
  notifications Notification[]
  announcements Announcement[]
  promotionsDecided PromotionRecommendation[] @relation("PromotionDecider")
  oauthAccounts OAuthAccount[]
  policiesAuthored        Policy[]                @relation("PolicyAuthor")
  policyAcks              PolicyAcknowledgement[]
  hiringRequestsReviewed  HiringRequest[]         @relation("HiringReviewer")
  savedViews              SavedView[]
}

model SavedView {
  id        String   @id @default(cuid())
  userId    String
  name      String
  path      String   // e.g. "/admin/audit-logs"
  query     String   // serialized URLSearchParams, e.g. "action=user.login&from=2026-01-01"
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, path, name])
  @@index([userId, path])
}

model OAuthAccount {
  id             String   @id @default(cuid())
  userId         String
  provider       String   // google | microsoft | ...
  providerSub    String   // unique subject identifier from the provider
  email          String?  // last-known email from provider (for support/debugging)
  createdAt      DateTime @default(now())
  lastUsedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSub])
  @@index([userId])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // super_admin, hr_admin, recruiter, manager, employee, finance, it_ops
  description String?
  permissions String   // JSON array of permission strings, e.g. ["employee:read", "leave:approve"]
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  userRoles UserRole[]
}

model UserRole {
  id       String  @id @default(cuid())
  userId   String
  roleId   String
  scope    String? // null = org-wide; otherwise departmentId for team-scoped

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, scope])
  @@index([userId])
}

// ────────────────────────────────────────────────────────────────────
// EMPLOYEE
// ────────────────────────────────────────────────────────────────────

model Department {
  id       String  @id @default(cuid())
  name     String  @unique
  parentId String?

  parent   Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentTree")
  employees Employee[]
  promotionsProposed PromotionRecommendation[]
  hiringRequests     HiringRequest[]
}

model Employee {
  id            String    @id @default(cuid())
  userId        String    @unique
  employeeCode  String    @unique
  firstName     String
  lastName      String
  dob           DateTime?
  joinDate      DateTime
  departmentId  String?
  managerId     String?
  jobTitle      String?
  status        String    @default("active") // active | onLeave | terminated
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  department  Department? @relation(fields: [departmentId], references: [id])
  manager     Employee?   @relation("Reports", fields: [managerId], references: [id])
  reports     Employee[]  @relation("Reports")

  profile           EmployeeProfile?
  diversity         EmployeeDiversity?
  employmentHistory EmploymentHistory[]
  salaryHistory     SalaryHistory[]
  documents         Document[]
  attendanceLogs    AttendanceLog[]
  employeeShifts    EmployeeShift[]
  leaveBalances     LeaveBalance[]
  leaveRequests     LeaveRequest[]
  payslips          Payslip[]
  skills            EmployeeSkill[]
  expenses          Expense[]
  goals             Goal[]              @relation("EmployeeGoals")
  goalsCreated      Goal[]              @relation("GoalCreator")
  reviewsAsSubject  Review[]            @relation("ReviewSubject")
  reviewsAsReviewer Review[]            @relation("ReviewReviewer")
  pipsAsSubject     PIP[]               @relation("PIPSubject")
  pipsAsManager     PIP[]               @relation("PIPManager")
  promotionsReceived PromotionRecommendation[] @relation("PromotionSubject")
  promotionsGiven    PromotionRecommendation[] @relation("PromotionRecommender")
  jobPostings       JobPosting[]
  interviewsLed     Interview[]
  assetAssignments    AssetAssignment[]
  licenseAssignments  LicenseAssignment[]
  recognitionsGiven    Recognition[]   @relation("RecogFrom")
  recognitionsReceived Recognition[]   @relation("RecogTo")
  eventsCreated        Event[]
  eventRSVPs           EventRSVP[]
  surveysCreated       Survey[]
  surveyResponses      SurveyResponse[]
  benefitEnrollments   BenefitEnrollment[]
  biometricCredentials BiometricCredential[]
  kpis                 KPI[]              @relation("KPISubject")
  kpisCreated          KPI[]              @relation("KPICreator")
  hiringRequests       HiringRequest[]    @relation("HiringRequester")
  overtimeEntries      OvertimeEntry[]
}

model EmployeeProfile {
  id                String  @id @default(cuid())
  employeeId        String  @unique
  phone             String?
  personalEmail     String?
  address           String?
  emergencyContacts String? // JSON: [{name, relation, phone}]

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model EmploymentHistory {
  id           String    @id @default(cuid())
  employeeId   String
  jobTitle     String
  departmentId String?
  startDate    DateTime
  endDate      DateTime?
  reason       String?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model SalaryHistory {
  id            String   @id @default(cuid())
  employeeId    String
  amount        Float
  currency      String   @default("USD")
  effectiveDate DateTime
  reason        String?
  createdAt     DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Document {
  id         String    @id @default(cuid())
  employeeId String
  type       String // contract | id | certification | other
  name       String
  s3Key      String
  expiresAt  DateTime?
  uploadedAt DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([expiresAt]) // for expiration alerts
}

model EmployeeSkill {
  id           String    @id @default(cuid())
  employeeId   String
  skill        String
  level        String? // beginner | intermediate | expert
  certifiedAt  DateTime?
  expiresAt    DateTime?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ────────────────────────────────────────────────────────────────────
// ATTENDANCE
// ────────────────────────────────────────────────────────────────────

model ShiftPattern {
  id            String  @id @default(cuid())
  name          String  @unique
  startTime     String // "09:00"
  endTime       String // "17:00"
  breakMinutes  Int     @default(60)
  workDays      String  @default("1,2,3,4,5") // CSV of weekday numbers (0=Sun)

  employeeShifts EmployeeShift[]
}

model EmployeeShift {
  id             String   @id @default(cuid())
  employeeId     String
  shiftPatternId String
  effectiveFrom  DateTime
  effectiveTo    DateTime?

  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftPattern ShiftPattern @relation(fields: [shiftPatternId], references: [id])
}

model AttendanceLog {
  id            String    @id @default(cuid())
  employeeId    String
  clockIn       DateTime
  clockOut      DateTime?
  source        String    @default("web") // web | mobile | biometric
  geoLat        Float?
  geoLng        Float?
  status        String    @default("regular") // regular | overtime | missed
  netHours      Float?    // working hours after regular breaks (namaz exempt)
  overtimeHours Float     @default(0) // counted overtime: max(0, netHours - 8 - 1hr grace)
  lateAlertedAt DateTime? // set when the "you are late" Slack ping fires (prevents repeats)
  notes         String?
  deviceId      String?

  employee Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  device   BiometricDevice?  @relation(fields: [deviceId], references: [id])
  breaks   BreakEvent[]

  @@index([employeeId, clockIn])
  @@index([deviceId, clockIn])
}

model BreakEvent {
  id              String    @id @default(cuid())
  attendanceLogId String
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  type            String    @default("regular") // regular | namaz

  attendanceLog AttendanceLog @relation(fields: [attendanceLogId], references: [id], onDelete: Cascade)

  @@index([attendanceLogId, startedAt])
}

// Employee-initiated record of extra hours worked outside the clock-in/out
// window (e.g. weekend work, late evening from home). Requires manager
// approval before counting toward the timesheet.
model OvertimeEntry {
  id          String    @id @default(cuid())
  employeeId  String
  workDate    DateTime  // calendar date the extra work was done (00:00 local)
  hours       Float     // self-reported extra hours (> 0)
  reason      String
  status      String    @default("pending") // pending | approved | rejected | cancelled
  approvalId  String?   // links to current Approval chain row
  createdAt   DateTime  @default(now())
  decidedAt   DateTime?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, status])
  @@index([workDate])
}

model BiometricDevice {
  id               String   @id @default(cuid())
  name             String
  location         String?
  vendor           String   @default("generic") // generic | zkteco | suprema | hikvision
  externalDeviceId String   @unique
  secretHash       String
  status           String   @default("active") // active | disabled
  lastSeenAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  credentials    BiometricCredential[]
  attendanceLogs AttendanceLog[]

  @@index([status])
}

model BiometricCredential {
  id                 String   @id @default(cuid())
  deviceId           String
  employeeId         String
  externalEmployeeId String
  label              String?
  createdAt          DateTime @default(now())

  device   BiometricDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  employee Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([deviceId, externalEmployeeId])
  @@index([employeeId])
}

// ────────────────────────────────────────────────────────────────────
// LEAVE
// ────────────────────────────────────────────────────────────────────

model LeavePolicy {
  id                  String  @id @default(cuid())
  name                String  @unique
  leaveType           String // vacation | sick | personal | unpaid
  annualEntitlement   Float   @default(0)
  accrualRule         String? // JSON: {type: "annual"|"monthly", amount}
  carryForwardMax     Float   @default(0)
  active              Boolean @default(true)
}

model LeaveBalance {
  id         String  @id @default(cuid())
  employeeId String
  leaveType  String
  balance    Float
  year       Int

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveType, year])
}

model LeaveRequest {
  id           String    @id @default(cuid())
  employeeId   String
  leaveType    String
  startDate    DateTime
  endDate      DateTime
  days         Float
  reason       String?
  status       String    @default("pending") // pending | approved | rejected | cancelled
  approvalId   String?   // links to current Approval chain row
  autoCreated  Boolean   @default(false) // true if generated by attendance.auto-leave-sweep
  createdAt    DateTime  @default(now())
  decidedAt    DateTime?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Holiday {
  id      String   @id @default(cuid())
  date    DateTime
  name    String
  country String   @default("US")

  @@unique([date, country])
}

// ────────────────────────────────────────────────────────────────────
// PAYROLL
// ────────────────────────────────────────────────────────────────────

model PayslipRun {
  id          String    @id @default(cuid())
  periodStart DateTime
  periodEnd   DateTime
  status      String    @default("draft") // draft | finalized
  createdAt   DateTime  @default(now())
  finalizedAt DateTime?

  payslips Payslip[]
}

model Payslip {
  id           String   @id @default(cuid())
  payslipRunId String
  employeeId   String
  grossPay     Float
  deductions   String // JSON: [{label, amount}]
  netPay       Float
  currency     String   @default("USD")
  s3Key        String? // PDF storage key
  createdAt    DateTime @default(now())

  payslipRun PayslipRun @relation(fields: [payslipRunId], references: [id])
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([payslipRunId, employeeId])
}

// ────────────────────────────────────────────────────────────────────
// INTERNAL COMMS — recognition, events, surveys
// ────────────────────────────────────────────────────────────────────

model Recognition {
  id            String   @id @default(cuid())
  fromEmployeeId String
  toEmployeeId   String
  category       String   @default("kudos") // kudos | thanks | achievement | teamwork
  message        String
  visibility     String   @default("public") // public | team
  createdAt      DateTime @default(now())

  from Employee @relation("RecogFrom", fields: [fromEmployeeId], references: [id], onDelete: Cascade)
  to   Employee @relation("RecogTo", fields: [toEmployeeId], references: [id], onDelete: Cascade)

  @@index([toEmployeeId, createdAt])
  @@index([visibility, createdAt])
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  capacity    Int?
  createdById String
  createdAt   DateTime  @default(now())

  createdBy Employee     @relation(fields: [createdById], references: [id])
  rsvps     EventRSVP[]

  @@index([startsAt])
}

model EventRSVP {
  id          String   @id @default(cuid())
  eventId     String
  employeeId  String
  status      String   @default("going") // going | maybe | notGoing
  respondedAt DateTime @default(now())

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([eventId, employeeId])
  @@index([eventId])
}

model Survey {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("draft") // draft | active | closed
  anonymous   Boolean   @default(false)
  questions   String // JSON: [{id, kind: 'rating'|'text'|'choice', label, options?, required?}]
  startsAt    DateTime?
  endsAt      DateTime?
  createdById String
  createdAt   DateTime  @default(now())

  createdBy Employee         @relation(fields: [createdById], references: [id])
  responses SurveyResponse[]

  @@index([status])
}

model SurveyResponse {
  id           String   @id @default(cuid())
  surveyId     String
  respondentId String?  // null for anonymous
  answers      String   // JSON: [{questionId, value}]
  submittedAt  DateTime @default(now())

  survey      Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  respondent  Employee? @relation(fields: [respondentId], references: [id], onDelete: SetNull)

  @@index([surveyId])
}

// ────────────────────────────────────────────────────────────────────
// ASSET MANAGEMENT
// ────────────────────────────────────────────────────────────────────

model Asset {
  id              String    @id @default(cuid())
  tag             String    @unique
  category        String // laptop | desktop | phone | tablet | monitor | accessory | other
  name            String
  serialNumber    String?   @unique
  status          String    @default("available") // available | assigned | maintenance | retired
  purchaseDate    DateTime?
  warrantyEndDate DateTime?
  purchaseCost    Float?
  currency        String    @default("USD")
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  assignments AssetAssignment[]

  @@index([status])
  @@index([category])
}

model AssetAssignment {
  id              String    @id @default(cuid())
  assetId         String
  employeeId      String
  assignedAt      DateTime  @default(now())
  returnedAt      DateTime?
  conditionReturn String? // good | damaged | missing
  notes           String?

  asset    Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([employeeId, returnedAt])
}

model SoftwareLicense {
  id           String    @id @default(cuid())
  name         String
  vendor       String?
  licenseType  String    @default("subscription") // perpetual | subscription
  seats        Int       @default(1)
  cost         Float?
  currency     String    @default("USD")
  renewalDate  DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignments LicenseAssignment[]

  @@index([renewalDate])
}

model LicenseAssignment {
  id         String    @id @default(cuid())
  licenseId  String
  employeeId String
  assignedAt DateTime  @default(now())
  revokedAt  DateTime?

  license  SoftwareLicense @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  employee Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([licenseId])
  @@index([employeeId, revokedAt])
}

// ────────────────────────────────────────────────────────────────────
// RECRUITMENT
// ────────────────────────────────────────────────────────────────────

model JobPosting {
  id           String    @id @default(cuid())
  title        String
  description  String
  departmentId String?
  location     String?
  employmentType String  @default("fullTime") // fullTime | partTime | contract | intern
  salaryMin    Float?
  salaryMax    Float?
  currency     String    @default("USD")
  status       String    @default("draft") // draft | open | closed | filled
  createdById  String
  openedAt     DateTime?
  closedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdBy  Employee     @relation(fields: [createdById], references: [id])
  candidates Candidate[]

  @@index([status])
}

model Candidate {
  id            String    @id @default(cuid())
  jobPostingId  String
  firstName     String
  lastName      String
  email         String
  phone         String?
  resumeS3Key   String?
  source        String?   // linkedIn | referral | direct | other
  stage         String    @default("applied") // applied | screening | interview | offer | hired | rejected
  notes         String?
  appliedAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  jobPosting JobPosting   @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  interviews Interview[]
  offer      Offer?

  @@index([jobPostingId, stage])
  @@index([email])
}

model Interview {
  id            String    @id @default(cuid())
  candidateId   String
  interviewerId String
  scheduledAt   DateTime
  type          String    @default("phone") // phone | onsite | technical | cultural | panel
  status        String    @default("scheduled") // scheduled | completed | cancelled | no_show
  rating        Int?      // 1..5
  feedback      String?
  recommendation String?  // hire | no_hire | maybe
  createdAt     DateTime  @default(now())

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interviewer Employee  @relation(fields: [interviewerId], references: [id])

  @@index([candidateId])
  @@index([interviewerId, status])
}

model Offer {
  id          String    @id @default(cuid())
  candidateId String    @unique
  salary      Float
  currency    String    @default("USD")
  startDate   DateTime
  status      String    @default("draft") // draft | sent | accepted | declined | withdrawn
  notes       String?
  sentAt      DateTime?
  decidedAt   DateTime?
  createdAt   DateTime  @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

// ────────────────────────────────────────────────────────────────────
// PERFORMANCE MANAGEMENT
// ────────────────────────────────────────────────────────────────────

model Goal {
  id          String    @id @default(cuid())
  employeeId  String
  createdById String
  title       String
  description String?
  type        String    @default("objective") // objective | keyResult | personal
  targetDate  DateTime?
  progress    Int       @default(0) // 0..100
  status      String    @default("active") // active | completed | cancelled
  parentId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee  Employee @relation("EmployeeGoals", fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy Employee @relation("GoalCreator", fields: [createdById], references: [id])
  parent    Goal?    @relation("GoalHierarchy", fields: [parentId], references: [id])
  children  Goal[]   @relation("GoalHierarchy")

  @@index([employeeId, status])
}

model ReviewCycle {
  id        String   @id @default(cuid())
  name      String   @unique
  startDate DateTime
  endDate   DateTime
  status    String   @default("draft") // draft | active | closed
  createdAt DateTime @default(now())

  reviews Review[]
}

model Review {
  id          String    @id @default(cuid())
  cycleId     String
  subjectId   String
  reviewerId  String
  type        String // self | manager | peer | upward
  status      String    @default("pending") // pending | submitted
  rating      Int?
  strengths   String?
  growthAreas String?
  comments   String?
  submittedAt DateTime?
  createdAt   DateTime  @default(now())

  cycle    ReviewCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  subject  Employee    @relation("ReviewSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  reviewer Employee    @relation("ReviewReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([cycleId, subjectId, reviewerId, type])
  @@index([reviewerId, status])
  @@index([subjectId])
}

model PIP {
  id          String    @id @default(cuid())
  subjectId   String
  managerId   String
  startDate   DateTime
  endDate     DateTime
  status      String    @default("active") // active | passed | failed | cancelled
  reason      String
  goals       String // JSON: [{title, dueDate, status}]
  checkpoints String    @default("[]") // JSON: [{date, notes, decision}]
  createdAt   DateTime  @default(now())
  closedAt    DateTime?

  subject Employee @relation("PIPSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  manager Employee @relation("PIPManager", fields: [managerId], references: [id], onDelete: Cascade)

  @@index([subjectId, status])
}

model PromotionRecommendation {
  id                String   @id @default(cuid())
  subjectId         String   // employee being recommended
  recommendedById   String   // manager making the recommendation
  proposedTitle     String
  proposedSalary    Float?
  proposedCurrency  String   @default("USD")
  proposedDepartmentId String?
  justification     String
  basedOnReviewIds  String   @default("[]") // JSON array of Review ids
  status            String   @default("pending") // pending | approved | rejected | withdrawn
  decidedById       String?
  decidedAt         DateTime?
  comments          String?
  createdAt         DateTime @default(now())

  subject       Employee    @relation("PromotionSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  recommendedBy Employee    @relation("PromotionRecommender", fields: [recommendedById], references: [id])
  decidedBy     User?       @relation("PromotionDecider", fields: [decidedById], references: [id])
  department    Department? @relation(fields: [proposedDepartmentId], references: [id])

  @@index([subjectId, status])
  @@index([recommendedById])
}

// ────────────────────────────────────────────────────────────────────
// EXPENSES & REIMBURSEMENTS
// ────────────────────────────────────────────────────────────────────

model Expense {
  id          String    @id @default(cuid())
  employeeId  String
  category    String // travel | meals | supplies | training | other
  amount      Float
  currency    String    @default("USD")
  description String?
  expenseDate DateTime
  status      String    @default("draft") // draft | submitted | approved | rejected | reimbursed
  submittedAt DateTime?
  decidedAt   DateTime?
  reimbursedAt DateTime?

  employee Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  receipts ExpenseReceipt[]

  @@index([employeeId, status])
  @@index([status])
}

model ExpenseReceipt {
  id         String   @id @default(cuid())
  expenseId  String
  name       String
  s3Key      String
  uploadedAt DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
}

// ────────────────────────────────────────────────────────────────────
// WORKFLOWS — generic approvals
// ────────────────────────────────────────────────────────────────────

model Approval {
  id         String    @id @default(cuid())
  entityType String // LeaveRequest | Expense | HiringRequest
  entityId   String
  approverId String
  level      Int       @default(1)
  status     String    @default("pending") // pending | waiting | approved | rejected
  comments   String?
  decidedAt  DateTime?
  createdAt  DateTime  @default(now())

  approver User @relation("ApproverUser", fields: [approverId], references: [id])

  @@index([entityType, entityId])
  @@index([approverId, status])
}

// ────────────────────────────────────────────────────────────────────
// AUDIT, NOTIFICATIONS, COMPLIANCE
// ────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String // employee.created, leave.approved, ...
  entityType String?
  entityId   String?
  before     String? // JSON
  after      String? // JSON
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId, createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  channel   String    @default("inApp") // inApp | email | slack
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  authorId  String
  publishedAt DateTime @default(now())

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model BenefitPlan {
  id              String   @id @default(cuid())
  name            String
  type            String   // health | dental | vision | life | retirement
  description     String?
  monthlyPremium  Decimal  @db.Decimal(12, 2)
  employerShare   Decimal  @db.Decimal(12, 2) @default(0)
  coversDependents Boolean @default(true)
  active          Boolean  @default(true)
  enrollOpensAt   DateTime?
  enrollClosesAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  enrollments BenefitEnrollment[]

  @@index([active, type])
}

model BenefitEnrollment {
  id            String   @id @default(cuid())
  employeeId    String
  planId        String
  coverageLevel String   @default("employee") // employee | employee+spouse | family
  status        String   @default("pending")  // pending | active | waived | terminated
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee   Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  plan       BenefitPlan       @relation(fields: [planId], references: [id])
  dependents BenefitDependent[]

  @@unique([employeeId, planId, effectiveFrom])
  @@index([employeeId, status])
}

model BenefitDependent {
  id           String   @id @default(cuid())
  enrollmentId String
  firstName    String
  lastName     String
  relation     String   // spouse | child | domestic_partner | other
  dob          DateTime?
  createdAt    DateTime @default(now())

  enrollment BenefitEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
}

// Self-disclosed diversity data — stored separately from Employee for
// stricter access controls and easier GDPR deletion. All fields optional;
// each enum includes a "prefer_not_to_say" value so respondents can decline
// while still recording that they answered.
model EmployeeDiversity {
  id               String   @id @default(cuid())
  employeeId       String   @unique
  gender           String?  // woman | man | non_binary | prefer_not_to_say | other
  pronouns         String?  // free text e.g. "she/her"
  ethnicity        String?  // asian | black | hispanic | native_american | pacific_islander | white | two_or_more | prefer_not_to_say
  veteranStatus    String?  // protected | not_protected | prefer_not_to_say
  disabilityStatus String?  // has_disability | no_disability | prefer_not_to_say
  updatedAt        DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model KPI {
  id           String   @id @default(cuid())
  employeeId   String
  name         String
  description  String?
  unit         String?
  target       Float
  actual       Float    @default(0)
  period       String   // e.g. "2026-Q1", "2026-05", "2026"
  status       String   @default("active") // active | closed
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee  Employee @relation("KPISubject", fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy Employee @relation("KPICreator", fields: [createdById], references: [id])

  @@index([employeeId, period])
  @@index([status])
}

model HiringRequest {
  id               String   @id @default(cuid())
  requestedById    String
  departmentId     String?
  jobTitle         String
  headcount        Int      @default(1)
  urgency          String   @default("normal") // low | normal | high | critical
  justification    String
  proposedBudget   Float?
  status           String   @default("pending") // pending | approved | rejected | withdrawn
  reviewedById     String?
  reviewedAt       DateTime?
  reviewerComments String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  requestedBy Employee    @relation("HiringRequester", fields: [requestedById], references: [id])
  department  Department? @relation(fields: [departmentId], references: [id])
  reviewedBy  User?       @relation("HiringReviewer", fields: [reviewedById], references: [id])

  @@index([requestedById, status])
  @@index([status, createdAt])
}

// Configurable approval rules. Evaluated in ascending `priority` for a given
// entityType; the first match's approverChain is used. Condition is JSON:
// { field, op, value } with op ∈ gte|lte|gt|lt|eq|in (empty {} = always match).
// approverChain is a JSON array of role selectors (manager|hr_admin|finance|super_admin).
model ApprovalRule {
  id            String   @id @default(cuid())
  name          String
  entityType    String   // LeaveRequest | Expense | HiringRequest
  priority      Int      @default(100)
  condition     String   @default("{}")
  approverChain String
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([entityType, active, priority])
}

model Policy {
  id           String   @id @default(cuid())
  title        String
  category     String   @default("general") // general | code_of_conduct | security | hr | finance
  body         String   // markdown
  version      Int      @default(1)
  requiresAck  Boolean  @default(true)
  active       Boolean  @default(true)
  publishedAt  DateTime @default(now())
  authorId     String
  updatedAt    DateTime @updatedAt

  author           User                    @relation("PolicyAuthor", fields: [authorId], references: [id])
  acknowledgements PolicyAcknowledgement[]

  @@index([active, category])
}

model PolicyAcknowledgement {
  id             String   @id @default(cuid())
  policyId       String
  userId         String
  version        Int
  acknowledgedAt DateTime @default(now())

  policy Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([policyId, userId, version])
  @@index([userId])
}
